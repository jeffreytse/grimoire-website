---
import { docsNav } from '../../config/docs-nav';

interface Props {
  currentSlug: string;
}

const { currentSlug } = Astro.props as Props;
---

<nav class="docs-sidebar-nav">
  {docsNav.map((section) => (
    <div class="mb-6">
      <h3 class="mb-2 px-3 text-xs font-semibold tracking-widest uppercase" style="color:#64748b">{section.title}</h3>
      <ul class="space-y-0.5">
        {section.items.map((item) => {
          const active = item.slug === currentSlug;
          return (
            <li>
              <a
                href={`/docs/${item.slug}`}
                aria-current={active ? 'page' : undefined}
                class="block rounded-lg px-3 py-1.5 text-sm transition-colors"
                style={active
                  ? 'background:rgba(201,147,58,0.12); color:#e8d08a; font-weight:600; border-left:2px solid #c9933a'
                  : 'color:#94a3b8; border-left:2px solid transparent'}
                onmouseover={active ? undefined : "this.style.color='#e8d08a'; this.style.background='rgba(201,147,58,0.06)'"}
                onmouseout={active ? undefined : "this.style.color='#94a3b8'; this.style.background='transparent'"}
              >
                {item.label}
              </a>
            </li>
          );
        })}
      </ul>
    </div>
  ))}
</nav>
