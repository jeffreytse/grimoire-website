---
// "Also supports" agent links — used on all product pages
---

<section class="px-6 py-16" style="background:#080c18">
  <div class="max-w-3xl mx-auto text-center">
    <p class="mb-3 text-sm font-semibold tracking-widest uppercase" style="color:#c9933a">Also supports</p>
    <h2 class="mb-8 text-2xl font-bold text-white">Grimoire works with every AI assistant</h2>
    <div class="flex flex-wrap justify-center gap-3">
      <a href="/claude" class="text-xs px-3 py-1.5 rounded-lg border transition-all" style="border-color:#1e2a3a; color:#94a3b8" onmouseover="this.style.borderColor='rgba(201,147,58,0.4)';this.style.color='#e8d08a'" onmouseout="this.style.borderColor='#1e2a3a';this.style.color='#94a3b8'">🤖 Claude Code</a>
      <a href="/codex" class="text-xs px-3 py-1.5 rounded-lg border transition-all" style="border-color:#1e2a3a; color:#94a3b8" onmouseover="this.style.borderColor='rgba(201,147,58,0.4)';this.style.color='#e8d08a'" onmouseout="this.style.borderColor='#1e2a3a';this.style.color='#94a3b8'">💻 Codex</a>
      <a href="/gemini" class="text-xs px-3 py-1.5 rounded-lg border transition-all" style="border-color:#1e2a3a; color:#94a3b8" onmouseover="this.style.borderColor='rgba(201,147,58,0.4)';this.style.color='#e8d08a'" onmouseout="this.style.borderColor='#1e2a3a';this.style.color='#94a3b8'">🔷 Gemini CLI</a>
      <a href="/copilot" class="text-xs px-3 py-1.5 rounded-lg border transition-all" style="border-color:#1e2a3a; color:#94a3b8" onmouseover="this.style.borderColor='rgba(201,147,58,0.4)';this.style.color='#e8d08a'" onmouseout="this.style.borderColor='#1e2a3a';this.style.color='#94a3b8'">🐙 Copilot</a>
      <a href="/opencode" class="text-xs px-3 py-1.5 rounded-lg border transition-all" style="border-color:#1e2a3a; color:#94a3b8" onmouseover="this.style.borderColor='rgba(201,147,58,0.4)';this.style.color='#e8d08a'" onmouseout="this.style.borderColor='#1e2a3a';this.style.color='#94a3b8'">🔵 OpenCode</a>
      <a href="/openclaw" class="text-xs px-3 py-1.5 rounded-lg border transition-all" style="border-color:#1e2a3a; color:#94a3b8" onmouseover="this.style.borderColor='rgba(201,147,58,0.4)';this.style.color='#e8d08a'" onmouseout="this.style.borderColor='#1e2a3a';this.style.color='#94a3b8'">🦞 OpenClaw</a>
    </div>
    <p class="mt-8 text-sm text-slate-500">Or install to all agents at once: <code style="color:#e8d08a">grimoire install --target all</code></p>
  </div>
</section>
