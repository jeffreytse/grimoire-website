---
import Layout from './Layout.astro';
import DocsSidebar from '../components/docs/DocsSidebar.astro';
import DocsToc from '../components/docs/DocsToc.astro';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  title: string;
  description: string;
  slug: string;
  headings: Heading[];
}

const { title, description, slug, headings } = Astro.props as Props;
---

<Layout title={title} description={description}>
  <nav style="background:#0d1120; border-bottom:1px solid #1e2a3a" class="px-4 sm:px-6 py-4 sticky top-0 z-50">
    <div class="max-w-[1400px] mx-auto flex items-center justify-between gap-4">
      <div class="flex items-center gap-4 min-w-0">
        <button
          id="docs-drawer-toggle"
          class="md:hidden flex items-center justify-center w-8 h-8 rounded-lg shrink-0"
          style="border:1px solid #1e2a3a; color:#94a3b8"
          aria-label="Toggle navigation"
        >
          ☰
        </button>
        <a href="/" class="flex items-center gap-2 text-sm font-medium transition-colors shrink-0" style="color:#94a3b8" onmouseover="this.style.color='#e8d08a'" onmouseout="this.style.color='#94a3b8'">
          ← Grimoire
        </a>
      </div>
      <div id="docs-search" class="flex-1 max-w-md mx-4 hidden sm:block"></div>
      <a href="https://github.com/jeffreytse/grimoire" target="_blank" class="text-sm font-medium transition-colors shrink-0" style="color:#c9933a" onmouseover="this.style.color='#e8d08a'" onmouseout="this.style.color='#c9933a'">
        ⭐ Star on GitHub
      </a>
    </div>
  </nav>

  <div class="max-w-[1400px] mx-auto px-4 sm:px-6 grid grid-cols-1 md:grid-cols-[220px_1fr] xl:grid-cols-[220px_1fr_220px] gap-8 py-10">
    <!-- Sidebar (desktop) -->
    <aside class="hidden md:block">
      <div class="sticky top-24 max-h-[calc(100vh-7rem)] overflow-y-auto pr-2">
        <DocsSidebar currentSlug={slug} />
      </div>
    </aside>

    <!-- Mobile drawer -->
    <div id="docs-drawer" class="hidden fixed inset-0 z-[60] md:hidden">
      <div id="docs-drawer-backdrop" class="absolute inset-0" style="background:rgba(0,0,0,0.6)"></div>
      <div class="absolute left-0 top-0 bottom-0 w-72 max-w-[80vw] overflow-y-auto p-5" style="background:#0d1120; border-right:1px solid #1e2a3a">
        <div class="flex items-center justify-between mb-6">
          <span class="text-sm font-semibold" style="color:#e2e8f0">Docs</span>
          <button id="docs-drawer-close" class="w-8 h-8 rounded-lg" style="border:1px solid #1e2a3a; color:#94a3b8" aria-label="Close navigation">✕</button>
        </div>
        <DocsSidebar currentSlug={slug} />
      </div>
    </div>

    <!-- Content -->
    <main class="min-w-0" data-pagefind-body>
      <article class="prose-doc">
        <slot />
      </article>
    </main>

    <!-- TOC (desktop, xl+) -->
    <aside class="hidden xl:block">
      <div class="sticky top-24">
        <DocsToc headings={headings} />
      </div>
    </aside>
  </div>

  <footer style="border-top:1px solid #1e2a3a; background:#080c18" class="mt-4 py-8 text-center">
    <p class="text-sm" style="color:#64748b">Grimoire is free and open-source under the MIT license · <a href="https://github.com/jeffreytse/grimoire" style="color:#c9933a" class="hover:underline">github.com/jeffreytse/grimoire</a></p>
  </footer>
</Layout>

<style is:global>
  .prose-doc {
    color: #cbd5e1;
    line-height: 1.75;
  }
  .prose-doc h1 { font-size: 2rem; font-weight: 800; color: #e8d08a; margin: 0 0 1.5rem; line-height: 1.2; }
  .prose-doc h2 { font-size: 1.375rem; font-weight: 700; color: #e2e8f0; margin: 2.5rem 0 1rem; padding-bottom: 0.5rem; border-bottom: 1px solid #1e2a3a; scroll-margin-top: 6rem; }
  .prose-doc h3 { font-size: 1.125rem; font-weight: 600; color: #e2e8f0; margin: 2rem 0 0.75rem; scroll-margin-top: 6rem; }
  .prose-doc h4 { font-size: 1rem; font-weight: 600; color: #94a3b8; margin: 1.5rem 0 0.5rem; }
  .prose-doc p { margin: 0 0 1.25rem; }
  .prose-doc a { color: #c9933a; text-decoration: underline; text-decoration-color: rgba(201,147,58,0.4); }
  .prose-doc a:hover { color: #e8d08a; text-decoration-color: #e8d08a; }
  .prose-doc code {
    font-family: 'JetBrains Mono', 'Fira Code', monospace;
    font-size: 0.875em;
    background: #111826;
    border: 1px solid #1e2a3a;
    border-radius: 4px;
    padding: 0.15em 0.4em;
    color: #e8d08a;
  }
  .prose-doc pre {
    position: relative;
    background: #0a0e1a;
    border: 1px solid #1e2a3a;
    border-radius: 8px;
    padding: 1.25rem;
    overflow-x: auto;
    margin: 0 0 1.5rem;
  }
  .prose-doc pre code {
    background: none;
    border: none;
    padding: 0;
    font-size: 0.875rem;
    color: #cbd5e1;
  }
  .prose-doc ul { padding-left: 1.5rem; margin: 0 0 1.25rem; list-style-type: disc; }
  .prose-doc ol { padding-left: 1.5rem; margin: 0 0 1.25rem; list-style-type: decimal; }
  .prose-doc li { margin-bottom: 0.5rem; }
  .prose-doc blockquote {
    border-left: 3px solid #c9933a;
    padding-left: 1.25rem;
    margin: 0 0 1.25rem;
    color: #94a3b8;
    font-style: italic;
  }
  .prose-doc table { width: 100%; border-collapse: collapse; margin: 0 0 1.5rem; font-size: 0.9rem; }
  .prose-doc th { text-align: left; padding: 0.625rem 1rem; background: #111826; color: #e2e8f0; font-weight: 600; border-bottom: 1px solid #1e2a3a; }
  .prose-doc td { padding: 0.625rem 1rem; border-bottom: 1px solid #1a2233; }
  .prose-doc tr:last-child td { border-bottom: none; }
  .prose-doc hr { border: none; border-top: 1px solid #1e2a3a; margin: 2rem 0; }
  .prose-doc strong { color: #e2e8f0; font-weight: 600; }

  .doc-copy-btn {
    position: absolute;
    top: 0.6rem;
    right: 0.6rem;
    padding: 0.25rem 0.6rem;
    font-size: 0.7rem;
    font-weight: 500;
    border-radius: 6px;
    border: 1px solid #1e2a3a;
    background: #111826;
    color: #94a3b8;
    cursor: pointer;
    transition: all 0.15s ease;
  }

  /* Pagefind UI palette override */
  #docs-search {
    --pagefind-ui-primary: #c9933a;
    --pagefind-ui-text: #cbd5e1;
    --pagefind-ui-background: #0d1120;
    --pagefind-ui-border: #1e2a3a;
    --pagefind-ui-tag: #111826;
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: 8px;
    --pagefind-ui-font: 'Inter', system-ui, sans-serif;
  }
  #docs-search .pagefind-ui__search-input {
    background: #111826;
    color: #e2e8f0;
  }
  #docs-search .pagefind-ui__drawer {
    background: #0d1120;
    border: 1px solid #1e2a3a;
  }
  #docs-search .pagefind-ui__result {
    border-bottom: 1px solid #1e2a3a;
  }
  #docs-search .pagefind-ui__result-title a,
  #docs-search .pagefind-ui__result-link {
    color: #e8d08a;
  }
</style>

<script>
  const toggle = document.getElementById('docs-drawer-toggle');
  const drawer = document.getElementById('docs-drawer');
  const backdrop = document.getElementById('docs-drawer-backdrop');
  const closeBtn = document.getElementById('docs-drawer-close');

  function openDrawer() { drawer?.classList.remove('hidden'); }
  function closeDrawer() { drawer?.classList.add('hidden'); }

  toggle?.addEventListener('click', openDrawer);
  closeBtn?.addEventListener('click', closeDrawer);
  backdrop?.addEventListener('click', closeDrawer);

  // Code block copy buttons
  document.querySelectorAll('.prose-doc pre').forEach((pre) => {
    const btn = document.createElement('button');
    btn.className = 'copy-btn doc-copy-btn';
    btn.textContent = 'Copy';
    btn.addEventListener('click', () => {
      const code = pre.querySelector('code');
      const text = code ? code.textContent ?? '' : pre.textContent ?? '';
      const done = () => {
        btn.textContent = 'Copied!';
        btn.classList.add('copied');
        setTimeout(() => {
          btn.textContent = 'Copy';
          btn.classList.remove('copied');
        }, 2000);
      };
      if (navigator.clipboard && window.isSecureContext) {
        navigator.clipboard.writeText(text).then(done).catch(() => {});
      } else {
        const ta = document.createElement('textarea');
        ta.value = text;
        ta.style.position = 'fixed';
        ta.style.opacity = '0';
        document.body.appendChild(ta);
        ta.focus();
        ta.select();
        try { document.execCommand('copy'); done(); } catch (_) {}
        document.body.removeChild(ta);
      }
    });
    pre.appendChild(btn);
  });

  // Pagefind UI (assets only exist after `pnpm build && pagefind --site dist`)
  (function loadPagefind() {
    const searchEl = document.getElementById('docs-search');
    if (!searchEl) return;
    const css = document.createElement('link');
    css.rel = 'stylesheet';
    css.href = '/pagefind/pagefind-ui.css';
    document.head.appendChild(css);

    const script = document.createElement('script');
    script.src = '/pagefind/pagefind-ui.js';
    script.onload = () => {
      // @ts-ignore
      if (window.PagefindUI) {
        // @ts-ignore
        new window.PagefindUI({ element: '#docs-search', showSubResults: true, showImages: false });
      }
    };
    script.onerror = () => {
      searchEl.innerHTML = '';
    };
    document.body.appendChild(script);
  })();
</script>
