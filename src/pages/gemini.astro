---
import Layout from '../layouts/Layout.astro';
import NavSimple from '../components/NavSimple.astro';
import DomainsGrid from '../components/DomainsGrid.astro';
import AgentLinks from '../components/AgentLinks.astro';
import FooterSimple from '../components/FooterSimple.astro';
---

<Layout
  title="Grimoire for Gemini CLI — Best Practices Skills"
  description="1000+ best practices skills for Google Gemini CLI. Install Grimoire in 60 seconds and get expert frameworks for engineering, law, medicine, finance, and 27 domains."
  ogTitle="Grimoire for Gemini CLI — Best Practices Skills"
  ogDescription="Install 1000+ best practices skills into Gemini CLI. Expert frameworks across 27 domains — free and open-source on GitHub. Auto-detected on install."
  ogImage="https://raw.githubusercontent.com/jeffreytse/grimoire/main/assets/banner-1280x640.svg"
  ogUrl="https://grimoire.jeffreytse.net/gemini"
  canonical="https://grimoire.jeffreytse.net/gemini"
  keywords="gemini cli best practices, gemini cli grimoire, gemini cli skills, best practices skills, AI assistant skills, grimoire, open source AI skills"
>
  <Fragment slot="head">
    <script type="application/ld+json">{`{
  "@context": "https://schema.org",
  "@type": "HowTo",
  "name": "How to install Grimoire for Gemini CLI",
  "description": "Install 1000+ best practices skills into Gemini CLI in under 60 seconds.",
  "totalTime": "PT1M",
  "step": [
    { "@type": "HowToStep", "position": 1, "name": "Run the install command", "text": "grimoire install --target gemini" },
    { "@type": "HowToStep", "position": 2, "name": "Skills install to ~/.gemini/skills/", "text": "Grimoire installs 1000+ best practices skill files. Gemini CLI loads them automatically." },
    { "@type": "HowToStep", "position": 3, "name": "Start using best practices", "text": "Describe any task. Grimoire routes to the matching expert skill and applies it before Gemini CLI responds." }
  ]
}`}</script>
  </Fragment>

  <NavSimple />

  <main>

  <section class="px-6 py-20 text-center" style="background:#080c18">
    <div class="max-w-3xl mx-auto">
      <div class="mb-4 text-5xl">🔷</div>
      <h1 class="mb-6 text-4xl font-black leading-tight tracking-tight md:text-6xl">
        <span class="text-white">Gemini CLI</span><br/>
        <span class="gold-gradient">Best Practices Skills</span>
      </h1>
      <p class="max-w-xl mx-auto mb-8 text-lg text-slate-400">
        Install 1000+ verified expert frameworks into Gemini CLI — engineering, law, medicine, finance, and 27 domains. Free and open-source.
      </p>
      <a href="https://github.com/jeffreytse/grimoire" target="_blank"
        class="inline-flex items-center gap-2 px-8 py-3.5 rounded-xl text-base font-bold transition-all"
        style="background:linear-gradient(135deg,#c9933a,#8b6220); color:#fff; box-shadow:0 4px 24px rgba(201,147,58,0.3)"
        onmouseover="this.style.transform='scale(1.03)'" onmouseout="this.style.transform='scale(1)'">
        View on GitHub →
      </a>
    </div>
  </section>

  <section class="px-6 py-16" style="background:#0d1120">
    <div class="max-w-2xl mx-auto">
      <p class="mb-3 text-sm font-semibold tracking-widest text-center uppercase" style="color:#c9933a">Installation</p>
      <h2 class="mb-8 text-3xl font-bold text-center text-white">Install Grimoire for Gemini CLI</h2>
      <div class="p-6 install-block">
        <pre class="text-sm text-slate-300 overflow-x-auto">curl -fsSL https://raw.githubusercontent.com/jeffreytse/grimoire/main/scripts/install.sh | bash
grimoire update
grimoire install --target gemini</pre>
        <p class="mt-3 text-xs text-slate-500">Auto-detects Gemini CLI and installs to <code style="color:#e8d08a">~/.gemini/skills/</code>.</p>
      </div>
      <p class="mt-4 text-sm text-center text-slate-500">Skills install to <code style="color:#e8d08a">~/.gemini/skills/</code> — Gemini CLI loads them automatically.</p>
    </div>
  </section>

  <DomainsGrid />

  <section class="px-6 py-16" style="background:#0d1120">
    <div class="max-w-3xl mx-auto">
      <p class="mb-3 text-sm font-semibold tracking-widest text-center uppercase" style="color:#c9933a">FAQ</p>
      <h2 class="mb-10 text-3xl font-bold text-center text-white">Gemini CLI + Grimoire</h2>
      <div class="space-y-5">
        <div class="p-6 rounded-xl" style="background:#0d1120; border:1px solid #1e2a3a">
          <h3 class="mb-3 text-lg font-semibold text-white">Where does Grimoire install skills for Gemini CLI?</h3>
          <p class="text-slate-400">Skills are installed to ~/.gemini/skills/. Gemini CLI reads GEMINI.md and skills from this directory automatically.</p>
        </div>
        <div class="p-6 rounded-xl" style="background:#0d1120; border:1px solid #1e2a3a">
          <h3 class="mb-3 text-lg font-semibold text-white">Does Grimoire auto-detect Gemini CLI?</h3>
          <p class="text-slate-400">Yes. The grimoire script checks for the gemini binary and installs to ~/.gemini/skills/ automatically when Gemini CLI is detected.</p>
        </div>
        <div class="p-6 rounded-xl" style="background:#0d1120; border:1px solid #1e2a3a">
          <h3 class="mb-3 text-lg font-semibold text-white">Can I install only specific domains for Gemini CLI?</h3>
          <p class="text-slate-400">Yes. Run grimoire --domain engineering --target gemini to install only the engineering domain.</p>
        </div>
        <div class="p-6 rounded-xl" style="background:#0d1120; border:1px solid #1e2a3a">
          <h3 class="mb-3 text-lg font-semibold text-white">Does Grimoire configure GEMINI.md automatically?</h3>
          <p class="text-slate-400">Yes. Grimoire writes the start-best-practice trigger to ~/.gemini/GEMINI.md so skills activate automatically on every Gemini CLI session.</p>
        </div>
      </div>
    </div>
  </section>

  <AgentLinks />

  </main>

  <FooterSimple />

</Layout>
