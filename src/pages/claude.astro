---
import Layout from '../layouts/Layout.astro';
import NavSimple from '../components/NavSimple.astro';
import DomainsGrid from '../components/DomainsGrid.astro';
import AgentLinks from '../components/AgentLinks.astro';
import FooterSimple from '../components/FooterSimple.astro';
---

<Layout
  title="Grimoire for Claude Code — Best Practices Skills"
  description="1000+ best practices skills for Claude Code by Anthropic. Install Grimoire in 60 seconds and get expert frameworks for engineering, law, medicine, finance, and 27 domains."
  ogTitle="Grimoire for Claude Code — Best Practices Skills"
  ogDescription="Install 1000+ best practices skills into Claude Code. Expert frameworks across engineering, law, medicine, finance, and 27 domains — free and open-source on GitHub."
  ogImage="https://raw.githubusercontent.com/jeffreytse/grimoire/main/assets/banner-1280x640.svg"
  ogUrl="https://grimoire.jeffreytse.net/claude"
  canonical="https://grimoire.jeffreytse.net/claude"
  keywords="claude code best practices, claude code grimoire, claude code skills, best practices skills, AI assistant skills, grimoire, open source AI skills"
>
  <Fragment slot="head">
    <script type="application/ld+json">{`{
  "@context": "https://schema.org",
  "@type": "HowTo",
  "name": "How to install Grimoire for Claude Code",
  "description": "Install 1000+ best practices skills into Claude Code in under 60 seconds.",
  "totalTime": "PT1M",
  "step": [
    { "@type": "HowToStep", "position": 1, "name": "Run the install command", "text": "grimoire install --target claude" },
    { "@type": "HowToStep", "position": 2, "name": "Skills install to ~/.claude/skills/", "text": "Grimoire installs 1000+ best practices skill files. Claude Code loads them automatically." },
    { "@type": "HowToStep", "position": 3, "name": "Start using best practices", "text": "Describe any task. Grimoire routes to the matching expert skill and applies it before Claude Code responds." }
  ]
}`}</script>
    <script type="application/ld+json">{`{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "How does Grimoire work with Claude Code?", "acceptedAnswer": { "@type": "Answer", "text": "Grimoire installs skill files into ~/.claude/skills/. Claude Code loads these automatically and routes your tasks through expert best-practices frameworks." } },
    { "@type": "Question", "name": "How do I install Grimoire for Claude Code?", "acceptedAnswer": { "@type": "Answer", "text": "Run /plugin marketplace add jeffreytse/grimoire, then /plugin install grimoire@grimoire inside Claude Code. Or use the grimoire CLI: curl -fsSL https://raw.githubusercontent.com/jeffreytse/grimoire/main/scripts/install.sh | bash, then run: grimoire update && grimoire install" } }
  ]
}`}</script>
  </Fragment>

  <NavSimple />

  <main>

  <section class="px-6 py-20 text-center" style="background:#080c18">
    <div class="max-w-3xl mx-auto">
      <div class="mb-4 text-5xl">🤖</div>
      <h1 class="mb-6 text-4xl font-black leading-tight tracking-tight md:text-6xl">
        <span class="text-white">Claude Code</span><br/>
        <span class="gold-gradient">Best Practices Skills</span>
      </h1>
      <p class="max-w-xl mx-auto mb-8 text-lg text-slate-400">
        Install 1000+ verified expert frameworks into Claude Code — engineering, law, medicine, finance, and 27 domains. Free and open-source.
      </p>
      <a href="https://github.com/jeffreytse/grimoire" target="_blank"
        class="inline-flex items-center gap-2 px-8 py-3.5 rounded-xl text-base font-bold transition-all"
        style="background:linear-gradient(135deg,#c9933a,#8b6220); color:#fff; box-shadow:0 4px 24px rgba(201,147,58,0.3)"
        onmouseover="this.style.transform='scale(1.03)'" onmouseout="this.style.transform='scale(1)'">
        View on GitHub →
      </a>
    </div>
  </section>

  <section class="px-6 py-16" style="background:#0d1120">
    <div class="max-w-2xl mx-auto">
      <p class="mb-3 text-sm font-semibold tracking-widest text-center uppercase" style="color:#c9933a">Installation</p>
      <h2 class="mb-8 text-3xl font-bold text-center text-white">Install Grimoire for Claude Code</h2>
      <div class="p-6 install-block">
        <p class="mb-2 text-xs font-semibold tracking-widest uppercase" style="color:#c9933a">Step 1 — Register marketplace</p>
        <pre class="mb-4 text-sm text-slate-300 overflow-x-auto">/plugin marketplace add jeffreytse/grimoire</pre>
        <p class="mb-2 text-xs font-semibold tracking-widest uppercase" style="color:#c9933a">Step 2 — Install all skills</p>
        <pre class="text-sm text-slate-300 overflow-x-auto">/plugin install grimoire@grimoire</pre>
      </div>
      <p class="mt-4 text-sm text-center text-slate-500">Skills install to <code style="color:#e8d08a">~/.claude/skills/</code> — Claude Code loads them automatically.</p>
    </div>
  </section>

  <DomainsGrid />

  <section class="px-6 py-16" style="background:#0d1120">
    <div class="max-w-3xl mx-auto">
      <p class="mb-3 text-sm font-semibold tracking-widest text-center uppercase" style="color:#c9933a">FAQ</p>
      <h2 class="mb-10 text-3xl font-bold text-center text-white">Claude Code + Grimoire</h2>
      <div class="space-y-5">
        <div class="p-6 rounded-xl" style="background:#0d1120; border:1px solid #1e2a3a">
          <h3 class="mb-3 text-lg font-semibold text-white">How does Grimoire work inside Claude Code?</h3>
          <p class="text-slate-400">Grimoire installs skill files into ~/.claude/skills/. Claude Code loads these automatically. When you describe a task, Grimoire intercepts and routes to the matching best-practices skill before Claude responds.</p>
        </div>
        <div class="p-6 rounded-xl" style="background:#0d1120; border:1px solid #1e2a3a">
          <h3 class="mb-3 text-lg font-semibold text-white">Does Grimoire affect all my Claude conversations?</h3>
          <p class="text-slate-400">Only conversations in directories where grimoire is active. Skills apply globally once installed — you can also scope per-project using a project-level CLAUDE.md.</p>
        </div>
        <div class="p-6 rounded-xl" style="background:#0d1120; border:1px solid #1e2a3a">
          <h3 class="mb-3 text-lg font-semibold text-white">Can I install only specific domains?</h3>
          <p class="text-slate-400">Yes. Run /plugin install grimoire-engineering@grimoire to install just the engineering domain, or grimoire --domain engineering --target claude for the script method.</p>
        </div>
        <div class="p-6 rounded-xl" style="background:#0d1120; border:1px solid #1e2a3a">
          <h3 class="mb-3 text-lg font-semibold text-white">Is Grimoire compatible with Claude Code plans?</h3>
          <p class="text-slate-400">Yes. Grimoire works with all Claude Code subscription tiers — Free, Pro, and Team. The skills run client-side; no additional API calls.</p>
        </div>
      </div>
    </div>
  </section>

  <AgentLinks />

  </main>

  <FooterSimple />

</Layout>
