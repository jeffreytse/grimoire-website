---
import Layout from '../layouts/Layout.astro';
import NavSimple from '../components/NavSimple.astro';
import DomainsGrid from '../components/DomainsGrid.astro';
import AgentLinks from '../components/AgentLinks.astro';
import FooterSimple from '../components/FooterSimple.astro';
---

<Layout
  title="Grimoire for Copilot — Best Practices Skills"
  description="1000+ best practices skills for GitHub Copilot CLI. Install Grimoire in 60 seconds and get expert frameworks for engineering, law, medicine, finance, and 26 domains."
  ogTitle="Grimoire for Copilot — Best Practices Skills"
  ogDescription="Install 1000+ best practices skills into GitHub Copilot. Expert frameworks across 26 domains — free and open-source on GitHub."
  ogImage="https://raw.githubusercontent.com/jeffreytse/grimoire/main/assets/banner-1280x640.svg"
  ogUrl="https://grimoire.jeffreytse.net/copilot"
  canonical="https://grimoire.jeffreytse.net/copilot"
  keywords="copilot best practices, copilot grimoire, copilot skills, best practices skills, AI assistant skills, grimoire, open source AI skills"
>
  <Fragment slot="head">
    <script type="application/ld+json">{
  "@context": "https://schema.org",
  "@type": "HowTo",
  "name": "How to install Grimoire for Copilot",
  "description": "Install 1000+ best practices skills into Copilot in under 60 seconds.",
  "totalTime": "PT1M",
  "step": [
    { "@type": "HowToStep", "position": 1, "name": "Run the install command", "text": "grimoire install --target all" },
    { "@type": "HowToStep", "position": 2, "name": "Skills install to Copilot plugin directory", "text": "Grimoire installs 1000+ best practices skill files. Copilot loads them automatically." },
    { "@type": "HowToStep", "position": 3, "name": "Start using best practices", "text": "Describe any task. Grimoire routes to the matching expert skill and applies it before Copilot responds." }
  ]
}</script>
  </Fragment>

  <NavSimple />

  <main>

  <section class="px-6 py-20 text-center" style="background:#080c18">
    <div class="max-w-3xl mx-auto">
      <div class="mb-4 text-5xl">🐙</div>
      <h1 class="mb-6 text-4xl font-black leading-tight tracking-tight md:text-6xl">
        <span class="text-white">Copilot</span><br/>
        <span class="gold-gradient">Best Practices Skills</span>
      </h1>
      <p class="max-w-xl mx-auto mb-8 text-lg text-slate-400">
        Install 1000+ verified expert frameworks into Copilot — engineering, law, medicine, finance, and 26 domains. Free and open-source.
      </p>
      <a href="https://github.com/jeffreytse/grimoire" target="_blank"
        class="inline-flex items-center gap-2 px-8 py-3.5 rounded-xl text-base font-bold transition-all"
        style="background:linear-gradient(135deg,#c9933a,#8b6220); color:#fff; box-shadow:0 4px 24px rgba(201,147,58,0.3)"
        onmouseover="this.style.transform='scale(1.03)'" onmouseout="this.style.transform='scale(1)'">
        View on GitHub →
      </a>
    </div>
  </section>

  <section class="px-6 py-16" style="background:#0d1120">
    <div class="max-w-2xl mx-auto">
      <p class="mb-3 text-sm font-semibold tracking-widest text-center uppercase" style="color:#c9933a">Installation</p>
      <h2 class="mb-8 text-3xl font-bold text-center text-white">Install Grimoire for Copilot</h2>
      <div class="p-6 install-block">
        <pre class="text-sm text-slate-300 overflow-x-auto">copilot plugin marketplace add jeffreytse/grimoire-core
copilot plugin install grimoire@grimoire-core</pre>
        <p class="mt-3 text-xs text-slate-500">Or use the grimoire CLI (installs to all detected agents):</p>
        <pre class="mt-2 text-sm text-slate-300">curl -fsSL https://raw.githubusercontent.com/jeffreytse/grimoire/main/scripts/install.sh | bash
grimoire update
grimoire install</pre>
      </div>
      <p class="mt-4 text-sm text-center text-slate-500">Skills install to <code style="color:#e8d08a">Copilot plugin directory</code> — Copilot loads them automatically.</p>
    </div>
  </section>

  <DomainsGrid />

  <section class="px-6 py-16" style="background:#0d1120">
    <div class="max-w-3xl mx-auto">
      <p class="mb-3 text-sm font-semibold tracking-widest text-center uppercase" style="color:#c9933a">FAQ</p>
      <h2 class="mb-10 text-3xl font-bold text-center text-white">Copilot + Grimoire</h2>
      <div class="space-y-5">
        <div class="p-6 rounded-xl" style="background:#0d1120; border:1px solid #1e2a3a">
          <h3 class="mb-3 text-lg font-semibold text-white">How do I install Grimoire for Copilot?</h3>
          <p class="text-slate-400">Run copilot plugin marketplace add jeffreytse/grimoire-core, then copilot plugin install grimoire@grimoire-core from your terminal. Copilot CLI will download and register the Grimoire plugin automatically.</p>
        </div>
        <div class="p-6 rounded-xl" style="background:#0d1120; border:1px solid #1e2a3a">
          <h3 class="mb-3 text-lg font-semibold text-white">Does the grimoire shell script install to Copilot?</h3>
          <p class="text-slate-400">Yes. Running the grimoire script with --target all installs to all detected agents including Copilot. Auto-detection checks for the copilot binary.</p>
        </div>
        <div class="p-6 rounded-xl" style="background:#0d1120; border:1px solid #1e2a3a">
          <h3 class="mb-3 text-lg font-semibold text-white">Can I use Grimoire skills in Copilot Chat?</h3>
          <p class="text-slate-400">Grimoire skills work with Copilot CLI. For Copilot Chat in VS Code, install the grimoire extension or use the shell script method.</p>
        </div>
        <div class="p-6 rounded-xl" style="background:#0d1120; border:1px solid #1e2a3a">
          <h3 class="mb-3 text-lg font-semibold text-white">Do I need a GitHub Copilot subscription?</h3>
          <p class="text-slate-400">Yes. You need an active GitHub Copilot subscription. Grimoire itself is free and open-source — it only requires Copilot to be installed and authenticated.</p>
        </div>
      </div>
    </div>
  </section>

  <AgentLinks />

  </main>

  <FooterSimple />

</Layout>
