---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const docs = await getCollection('docs');
  return docs.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content, headings } = await render(entry);

const title = entry.data.title ?? entry.id.replace(/-/g, ' ').replace(/\b\w/g, c => c.toUpperCase());
const description = entry.data.description ?? `Grimoire documentation: ${title}`;
---

<Layout title={`${title} — Grimoire`} description={description}>
  <nav style="background:#0d1120; border-bottom:1px solid #1e2a3a" class="px-6 py-4 sticky top-0 z-50">
    <div class="max-w-4xl mx-auto flex items-center justify-between gap-4">
      <a href="/" class="flex items-center gap-2 text-sm font-medium transition-colors" style="color:#94a3b8" onmouseover="this.style.color='#e8d08a'" onmouseout="this.style.color='#94a3b8'">
        ← Grimoire
      </a>
      <a href="https://github.com/jeffreytse/grimoire-skills" target="_blank" class="text-sm font-medium transition-colors" style="color:#c9933a" onmouseover="this.style.color='#e8d08a'" onmouseout="this.style.color='#c9933a'">
        ⭐ Star on GitHub
      </a>
    </div>
  </nav>

  <main class="max-w-4xl mx-auto px-6 py-12">
    <article class="prose-doc">
      <Content />
    </article>
  </main>

  <footer style="border-top:1px solid #1e2a3a; background:#080c18" class="mt-16 py-8 text-center">
    <p class="text-sm" style="color:#64748b">© 2025 grimoire · <a href="https://github.com/jeffreytse/grimoire-skills" style="color:#c9933a" class="hover:underline">GitHub</a></p>
  </footer>
</Layout>

<style is:global>
  .prose-doc {
    color: #cbd5e1;
    line-height: 1.75;
    max-width: 72ch;
  }
  .prose-doc h1 { font-size: 2rem; font-weight: 800; color: #e8d08a; margin: 0 0 1.5rem; line-height: 1.2; }
  .prose-doc h2 { font-size: 1.375rem; font-weight: 700; color: #e2e8f0; margin: 2.5rem 0 1rem; padding-bottom: 0.5rem; border-bottom: 1px solid #1e2a3a; }
  .prose-doc h3 { font-size: 1.125rem; font-weight: 600; color: #e2e8f0; margin: 2rem 0 0.75rem; }
  .prose-doc h4 { font-size: 1rem; font-weight: 600; color: #94a3b8; margin: 1.5rem 0 0.5rem; }
  .prose-doc p { margin: 0 0 1.25rem; }
  .prose-doc a { color: #c9933a; text-decoration: underline; text-decoration-color: rgba(201,147,58,0.4); }
  .prose-doc a:hover { color: #e8d08a; text-decoration-color: #e8d08a; }
  .prose-doc code {
    font-family: 'JetBrains Mono', 'Fira Code', monospace;
    font-size: 0.875em;
    background: #111826;
    border: 1px solid #1e2a3a;
    border-radius: 4px;
    padding: 0.15em 0.4em;
    color: #e8d08a;
  }
  .prose-doc pre {
    background: #0a0e1a;
    border: 1px solid #1e2a3a;
    border-radius: 8px;
    padding: 1.25rem;
    overflow-x: auto;
    margin: 0 0 1.5rem;
  }
  .prose-doc pre code {
    background: none;
    border: none;
    padding: 0;
    font-size: 0.875rem;
    color: #cbd5e1;
  }
  .prose-doc ul { padding-left: 1.5rem; margin: 0 0 1.25rem; list-style-type: disc; }
  .prose-doc ol { padding-left: 1.5rem; margin: 0 0 1.25rem; list-style-type: decimal; }
  .prose-doc li { margin-bottom: 0.5rem; }
  .prose-doc blockquote {
    border-left: 3px solid #c9933a;
    padding-left: 1.25rem;
    margin: 0 0 1.25rem;
    color: #94a3b8;
    font-style: italic;
  }
  .prose-doc table { width: 100%; border-collapse: collapse; margin: 0 0 1.5rem; font-size: 0.9rem; }
  .prose-doc th { text-align: left; padding: 0.625rem 1rem; background: #111826; color: #e2e8f0; font-weight: 600; border-bottom: 1px solid #1e2a3a; }
  .prose-doc td { padding: 0.625rem 1rem; border-bottom: 1px solid #1a2233; }
  .prose-doc tr:last-child td { border-bottom: none; }
  .prose-doc hr { border: none; border-top: 1px solid #1e2a3a; margin: 2rem 0; }
  .prose-doc strong { color: #e2e8f0; font-weight: 600; }
</style>
