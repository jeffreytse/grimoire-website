---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Grimoire — Best Practices for Claude, OpenCode, OpenClaw & Every AI"
  description="1000+ best practices skills for Claude, Codex, Copilot, OpenCode, Gemini & every AI assistant. Free and open-source on GitHub — expert frameworks for engineering, law, medicine, finance, and 26 domains."
  ogTitle="Grimoire — Best Practices for Claude, OpenCode, OpenClaw & Every AI"
  ogDescription="1000+ best practices skills for Claude, Codex, Copilot, OpenCode, OpenClaw, Gemini, and every AI assistant. Free on GitHub — engineering, law, medicine, finance, and 26 domains. Start in 60 seconds."
  ogImage="https://raw.githubusercontent.com/jeffreytse/grimoire/main/assets/banner-1280x640.svg"
  ogUrl="https://grimoire.jeffreytse.net/"
  canonical="https://grimoire.jeffreytse.net/"
  keywords="best practice driven development, BPDD, BPDD methodology, claude best practices, codex best practices, copilot best practices, opencode best practices, openclaw best practices, gemini best practices, best practices skills, best practices github, AI skills, Claude Code skills, open source AI skills, expert skills, Cursor, engineering, AI assistant, grimoire"
>
  <Fragment slot="head">
    <script type="application/ld+json">{
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "Grimoire",
  "url": "https://grimoire.jeffreytse.net/",
  "description": "1000+ best practices skills for Claude, Codex, Copilot, OpenCode, Gemini, and every AI assistant. Free and open-source on GitHub.",
  "applicationCategory": "DeveloperApplication",
  "operatingSystem": "Any",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
  "author": { "@type": "Person", "name": "jeffreytse", "url": "https://github.com/jeffreytse" },
  "license": "https://opensource.org/licenses/MIT",
  "codeRepository": "https://github.com/jeffreytse/grimoire",
  "keywords": "claude best practices, codex best practices, copilot best practices, opencode best practices, openclaw best practices, gemini best practices, best practices skills, best practices github, AI skills, open source, engineering, law, medicine, finance",
  "image": "https://raw.githubusercontent.com/jeffreytse/grimoire/main/assets/banner-1280x640.svg"
}</script>
    <script type="application/ld+json">{
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "Grimoire",
  "url": "https://grimoire.jeffreytse.net/",
  "description": "Best practices skills for Claude, Codex, Copilot, OpenCode, OpenClaw, Gemini and every AI assistant"
}</script>
    <script type="application/ld+json">{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "What is Grimoire?", "acceptedAnswer": { "@type": "Answer", "text": "Grimoire is a free, open-source collection of 1000+ best practices skills for Claude, Codex, Copilot, OpenCode, Gemini CLI, and every AI assistant. Available on GitHub under the MIT license." } },
    { "@type": "Question", "name": "What Claude best practices skills are included?", "acceptedAnswer": { "@type": "Answer", "text": "Grimoire includes 1000+ best practices skills across 26 domains — engineering, law, medicine, finance, writing, design, marketing, health, and more. Each skill encodes a proven expert framework that Claude follows step-by-step." } },
    { "@type": "Question", "name": "Is Grimoire free on GitHub?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Grimoire is free and open-source, published at https://github.com/jeffreytse/grimoire under the MIT license. Install with one command into Claude Code, Cursor, Codex, Copilot, or Gemini CLI." } },
    { "@type": "Question", "name": "How do I use best practices skills with Claude?", "acceptedAnswer": { "@type": "Answer", "text": "Run /plugin marketplace add jeffreytse/grimoire-core, then /plugin install grimoire@grimoire-core. Claude will automatically detect and apply the relevant best practices skill for any task you describe." } },
    { "@type": "Question", "name": "Does Grimoire work with Codex, Copilot, and OpenCode?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. Grimoire provides best practices skills for Codex, Copilot, OpenCode, Claude, Gemini CLI, Cursor, and every major AI assistant. Install once with the grimoire script and all supported agents detect it automatically." } },
    { "@type": "Question", "name": "Is Grimoire just a skill library, or does it enforce anything?", "acceptedAnswer": { "@type": "Answer", "text": "Both. Grimoire is a package manager for best practices — install, manage, and update skills the way npm manages packages — with a built-in compliance linter. Run grimoire check to verify any artifact against your declared standards, the same way ESLint checks code style." } }
  ]
}</script>
  </Fragment>

  <Nav />

  <main>

  <!-- HERO -->
  <section class="relative flex items-center justify-center min-h-screen pt-20 overflow-hidden">
    <div class="stars" id="stars"></div>
    <div class="absolute inset-0 hero-glow"></div>
    <div class="absolute rounded-full pointer-events-none top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-96 h-96" style="background:radial-gradient(circle, rgba(201,147,58,0.08) 0%, transparent 70%)"></div>

    <div class="relative z-10 max-w-4xl px-6 mx-auto text-center">
      <div class="flex justify-center mb-8">
        <img
          src="https://raw.githubusercontent.com/jeffreytse/grimoire/main/assets/icon-book.svg"
          alt="Grimoire"
          class="w-36 h-36 animate-float drop-shadow-2xl"
          style="filter: drop-shadow(0 0 24px rgba(201,147,58,0.4))"
        />
      </div>

      <h1 class="mb-6 text-5xl font-black leading-tight tracking-tight md:text-7xl">
        <span class="text-white">Best Practices</span><br/>
        <span class="gold-gradient">for Everyone</span>
      </h1>

      <p class="max-w-2xl mx-auto mb-4 text-xl font-light leading-relaxed md:text-2xl text-slate-400">
        The world's knowledge is in your AI.<br/>
        <span class="font-medium text-slate-300">The world's practice is not.</span><br/>
        <span class="text-base text-slate-500">Most people don't know which practice applies — and AI won't enforce one unless guided. Grimoire closes both gaps.</span><br/>
        <span class="text-base font-medium" style="color:#e8d08a">Install like a package manager. Enforce like a linter.</span>
      </p>
      <p class="max-w-xl mx-auto mb-10 text-base text-slate-500">
        <span id="hero-total">1000+</span> verified best practices across <span id="hero-domains">26</span> domains — engineering, law, medicine, finance, and more.
        Works with every major AI assistant.
      </p>
      <p class="sr-only">
        Claude best practices, Codex best practices, Copilot best practices, OpenCode best practices, OpenClaw best practices, Gemini best practices — one library, every AI assistant.
      </p>

      <div class="max-w-xl p-4 mx-auto mb-8 install-block">
        <div class="flex items-start justify-between gap-4">
          <pre class="flex-1 min-w-0 overflow-x-auto text-sm text-slate-300" id="hero-cmd"><span style="color:#c9933a">$</span> curl -fsSL https://raw.githubusercontent.com/jeffreytse/grimoire/main/scripts/install.sh | bash
<span style="color:#c9933a">$</span> grimoire update
<span style="color:#c9933a">$</span> grimoire install</pre>
          <button
            id="hero-copy"
            class="copy-btn flex-shrink-0 px-3 py-1.5 rounded text-xs font-medium transition-all text-slate-400 border border-night-border"
            onclick="copyText('curl -fsSL https://raw.githubusercontent.com/jeffreytse/grimoire/main/scripts/install.sh | bash\\ngrimoire update\\ngrimoire install', 'hero-copy')"
            title="Copy"
          >
            Copy
          </button>
        </div>
      </div>

      <div class="flex flex-col justify-center sm:flex-row gap-4">
        <a
          href="https://github.com/jeffreytse/grimoire"
          target="_blank"
          class="flex items-center justify-center gap-2 px-8 py-3.5 rounded-xl text-base font-bold transition-all animate-pulse-gold"
          style="background:linear-gradient(135deg,#c9933a,#8b6220); color:#fff; box-shadow:0 4px 24px rgba(201,147,58,0.3)"
          onmouseover="this.style.transform='scale(1.03)'; this.style.boxShadow='0 6px 32px rgba(201,147,58,0.45)'"
          onmouseout="this.style.transform='scale(1)'; this.style.boxShadow='0 4px 24px rgba(201,147,58,0.3)'"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
          Star on GitHub
        </a>
        <a
          href="#domains"
          class="flex items-center justify-center gap-2 px-8 py-3.5 rounded-xl text-base font-semibold transition-all"
          style="border:1px solid #1e2a3a; color:#94a3b8;"
          onmouseover="this.style.borderColor='rgba(201,147,58,0.4)'; this.style.color='#e8d08a'; this.style.background='rgba(201,147,58,0.05)'"
          onmouseout="this.style.borderColor='#1e2a3a'; this.style.color='#94a3b8'; this.style.background='transparent'"
        >
          Browse <span id="cta-total">1000+</span> Skills
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
        </a>
      </div>
    </div>

    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce text-slate-600">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
    </div>
  </section>

  <!-- STATS BAR -->
  <section class="py-10 border-y" style="border-color:#1e2a3a; background:#0d1120">
    <div class="max-w-5xl px-6 mx-auto">
      <div class="text-center grid grid-cols-2 md:grid-cols-4 gap-6">
        <div class="reveal">
          <div id="domain-total-label" class="text-4xl font-black gold-gradient">1000+</div>
          <div class="mt-1 text-sm tracking-wider uppercase text-slate-500">Skills</div>
        </div>
        <div class="reveal">
          <div class="text-4xl font-black counter gold-gradient" data-target="26">0</div>
          <div class="mt-1 text-sm tracking-wider uppercase text-slate-500">Domains</div>
        </div>
        <div class="reveal">
          <div class="text-4xl font-black counter gold-gradient" data-target="6">0</div>
          <div class="mt-1 text-sm tracking-wider uppercase text-slate-500">AI Platforms</div>
        </div>
        <div class="reveal">
          <div class="text-4xl font-black text-slate-300">MIT</div>
          <div class="mt-1 text-sm tracking-wider uppercase text-slate-500">License</div>
        </div>
      </div>
    </div>
  </section>

  <!-- THE HOOK -->
  <section class="px-6 py-24" style="background:#080c18">
    <div class="max-w-4xl mx-auto text-center reveal">
      <p class="mb-6 text-sm font-semibold tracking-widest uppercase" style="color:#c9933a">The Problem</p>
      <h2 class="mb-6 text-4xl font-bold leading-tight text-white md:text-5xl">
        Your AI knows everything.<br/>
        <span class="text-slate-400">Knowing and doing are different.</span>
      </h2>
      <p class="max-w-2xl mx-auto mb-16 text-lg leading-relaxed text-slate-400">
        McKinsey charges $1M for frameworks your AI already has access to. A lawyer charges $800/hour for contracts. A doctor charges $300 for advice rooted in evidence your AI can find.
        <span class="text-slate-300"> Grimoire encodes the expert's playbook — the 10,000-hour practitioner's exact steps — and makes it available to everyone.</span>
      </p>

      <div class="max-w-3xl mx-auto text-left grid md:grid-cols-2 gap-6">
        <div class="p-6 rounded-xl" style="background:#111826; border:1px solid #1e2a3a">
          <div class="mb-4 text-sm font-semibold tracking-wider text-red-400 uppercase">Without Grimoire</div>
          <ul class="text-sm space-y-3 text-slate-400">
            <li class="flex gap-3"><span class="text-red-500 mt-0.5">✗</span> "Write a business strategy" → generic advice</li>
            <li class="flex gap-3"><span class="text-red-500 mt-0.5">✗</span> "Review my contract" → vague suggestions</li>
            <li class="flex gap-3"><span class="text-red-500 mt-0.5">✗</span> "Debug my architecture" → surface observations</li>
            <li class="flex gap-3"><span class="text-red-500 mt-0.5">✗</span> "Plan my workout" → generic fitness tips</li>
          </ul>
        </div>
        <div class="p-6 rounded-xl" style="background:#0f1c12; border:1px solid rgba(74,222,128,0.2)">
          <div class="mb-4 text-sm font-semibold tracking-wider text-green-400 uppercase">With Grimoire</div>
          <ul class="text-sm space-y-3 text-slate-300">
            <li class="flex gap-3"><span class="text-green-400 mt-0.5">✓</span> Surfaces McKinsey 7S + guides you through MECE decomposition</li>
            <li class="flex gap-3"><span class="text-green-400 mt-0.5">✓</span> Surfaces ABA clause standards + guides negotiation step by step</li>
            <li class="flex gap-3"><span class="text-green-400 mt-0.5">✓</span> Surfaces Google SRE runbooks + guides architecture review</li>
            <li class="flex gap-3"><span class="text-green-400 mt-0.5">✓</span> Surfaces NSCA periodization + guides your training program</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- DEMO -->
  <section class="px-6 py-20" style="background:#0d1120">
    <div class="max-w-4xl mx-auto reveal">
      <div class="mb-12 text-center">
        <p class="mb-4 text-sm font-semibold tracking-widest uppercase" style="color:#c9933a">See It In Action</p>
        <h2 class="mb-4 text-3xl font-bold text-white md:text-4xl">One question. Four practices you didn't know applied.</h2>
        <p class="max-w-xl mx-auto text-slate-400">Ask your AI about a real problem. Grimoire surfaces the right expert standard and guides you through applying it.</p>
      </div>

      <div class="mb-8 overflow-hidden border rounded-2xl" style="border-color:#1e2a3a; box-shadow:0 0 60px rgba(201,147,58,0.08)">
        <img
          src="https://raw.githubusercontent.com/jeffreytse/grimoire/main/assets/demo.gif"
          alt="Grimoire demo — AI routing through expert skills"
          class="w-full"
          loading="lazy"
        />
      </div>

      <div class="p-5 text-sm rounded-xl" style="background:#111826; border:1px solid #1e2a3a">
        <p class="mb-3 text-slate-400">
          <span class="font-semibold text-gold-light">Prompt:</span>
          <span class="italic text-slate-300"> "We're launching our SaaS in 48 hours. I'm terrified something will break. What do we do?"</span>
        </p>
        <p class="mb-2 text-xs font-medium tracking-wider uppercase text-slate-500">Surfaced and applied — 4 practices:</p>
        <div class="flex flex-wrap gap-2">
          <span class="px-3 py-1 text-xs font-medium rounded-full" style="background:rgba(201,147,58,0.15); color:#e8d08a; border:1px solid rgba(201,147,58,0.3)">apply-premortem</span>
          <span class="px-3 py-1 text-xs font-medium rounded-full" style="background:rgba(201,147,58,0.15); color:#e8d08a; border:1px solid rgba(201,147,58,0.3)">design-slo</span>
          <span class="px-3 py-1 text-xs font-medium rounded-full" style="background:rgba(201,147,58,0.15); color:#e8d08a; border:1px solid rgba(201,147,58,0.3)">plan-incident-response</span>
          <span class="px-3 py-1 text-xs font-medium rounded-full" style="background:rgba(201,147,58,0.15); color:#e8d08a; border:1px solid rgba(201,147,58,0.3)">run-game-day</span>
        </div>
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section class="px-6 py-20" style="background:#080c18">
    <div class="max-w-3xl mx-auto reveal">
      <div class="mb-16 text-center">
        <p class="mb-4 text-sm font-semibold tracking-widest uppercase" style="color:#c9933a">How It Works</p>
        <h2 class="text-3xl font-bold text-white md:text-4xl">From zero to expert in 4 steps</h2>
      </div>
      <div class="relative">
        <div class="space-y-12">
          <div class="flex gap-6">
            <div class="flex flex-col items-center">
              <div class="z-10 flex items-center justify-center w-10 h-10 text-sm font-bold rounded-full shrink-0" style="background:linear-gradient(135deg,#c9933a,#8b6220); color:#fff">1</div>
              <div class="flex-1 w-px mt-2" style="background:rgba(201,147,58,0.2)"></div>
            </div>
            <div class="pb-12">
              <h3 class="mb-2 text-lg font-bold text-white">Install once, everywhere</h3>
              <p class="text-sm leading-relaxed text-slate-400">One command installs grimoire into every AI agent on your system. Claude Code, Cursor, Codex, Gemini CLI, OpenCode, OpenClaw — all detect it automatically.</p>
            </div>
          </div>
          <div class="flex gap-6">
            <div class="flex flex-col items-center">
              <div class="z-10 flex items-center justify-center w-10 h-10 text-sm font-bold rounded-full shrink-0" style="background:linear-gradient(135deg,#c9933a,#8b6220); color:#fff">2</div>
              <div class="flex-1 w-px mt-2" style="background:rgba(201,147,58,0.2)"></div>
            </div>
            <div class="pb-12">
              <h3 class="mb-2 text-lg font-bold text-white">Intercepts before you ask</h3>
              <p class="text-sm leading-relaxed text-slate-400">You don't have to know the right prompt. When you start any task, Grimoire silently checks for applicable best practices and applies or offers them proactively — before you even describe a problem.</p>
            </div>
          </div>
          <div class="flex gap-6">
            <div class="flex flex-col items-center">
              <div class="z-10 flex items-center justify-center w-10 h-10 text-sm font-bold rounded-full shrink-0" style="background:linear-gradient(135deg,#c9933a,#8b6220); color:#fff">3</div>
              <div class="flex-1 w-px mt-2" style="background:rgba(201,147,58,0.2)"></div>
            </div>
            <div class="pb-12">
              <h3 class="mb-2 text-lg font-bold text-white">Ask your AI naturally</h3>
              <p class="text-sm leading-relaxed text-slate-400">You don't need to know which best practice applies. Just describe your problem — the AI finds the matching skill and routes through it automatically.</p>
            </div>
          </div>
          <div class="flex gap-6">
            <div class="flex flex-col items-center">
              <div class="z-10 flex items-center justify-center w-10 h-10 text-sm font-bold rounded-full shrink-0" style="background:linear-gradient(135deg,#c9933a,#8b6220); color:#fff">4</div>
            </div>
            <div>
              <h3 class="mb-2 text-lg font-bold text-white">Get expert-grade output</h3>
              <p class="text-sm leading-relaxed text-slate-400">Your AI follows the same frameworks as top institutions — McKinsey, Google, WHO, ABA, NSCA — and produces actionable, verifiable, specific output. Not summaries. Steps.</p>
              <div class="p-4 mt-4 rounded-xl" style="background:#111826; border:1px solid rgba(201,147,58,0.3)">
                <div class="mb-2 text-sm font-bold" style="color:#e8d08a">Enforce it automatically</div>
                <p class="mb-3 text-sm leading-relaxed text-slate-400">Declare your quality standard once in <code style="color:#e8d08a">settings.toml</code>. <a href="/bpdd" style="color:#c9933a" onmouseover="this.style.color='#e8d08a'" onmouseout="this.style.color='#c9933a'">Best Practice Driven Development (BPDD)</a> checks every artifact against it automatically — like a linter, for practices instead of syntax.</p>
                <pre class="text-xs overflow-x-auto text-slate-300" style="background:#0a0e1a; border:1px solid #1e2a3a; border-radius:6px; padding:0.75rem"><span style="color:#c9933a">$</span> grimoire check</pre>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- PREFERENCE MEMORY -->
  <section class="px-6 py-16" style="background:#0d1120; border-top:1px solid #1e2a3a">
    <div class="max-w-3xl mx-auto text-center reveal">
      <p class="mb-3 text-sm font-semibold tracking-widest uppercase" style="color:#c9933a">Respects Your Choices</p>
      <h2 class="mb-4 text-2xl font-bold text-white md:text-3xl">Grimoire learns what you've already chosen.</h2>
      <p class="max-w-2xl mx-auto text-sm leading-relaxed text-slate-400">
        Already using a practice intentionally? Audit your existing work to detect what's applied.
        Pin preferences at the session, project, or global level —
        routing skills respect them and never suggest alternatives for pinned choices.
      </p>
    </div>
  </section>

  <!-- DOMAINS -->
  <section id="domains" class="px-6 py-20" style="background:#0d1120">
    <div class="mx-auto max-w-7xl">
      <div class="mb-12 text-center reveal">
        <p id="domain-count-label" class="mb-4 text-sm font-semibold tracking-widest uppercase" style="color:#c9933a">26 Domains</p>
        <h2 class="mb-4 text-3xl font-bold text-white md:text-4xl">Every field. Every expert.</h2>
        <p class="max-w-xl mx-auto text-slate-400">A McKinsey engagement costs $1M. A senior lawyer bills $800/hr. The practices they follow are not proprietary — they belong to everyone. Browse <span id="domains-section-total">1000+</span> skills across every professional domain, free.</p>
      </div>

      <!-- 26 user-facing subject domains. The `meta` domain (routing/framework skills) is intentionally excluded — it's not a subject a user browses. -->
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 gap-3 reveal">
        <a href="https://github.com/jeffreytse/grimoire-core/tree/main/skills/engineering" target="_blank" class="p-4 domain-card" data-domain="engineering">
          <div class="mb-2 text-2xl">⚙️</div>
          <div class="text-sm font-semibold text-slate-200">Engineering</div>
          <div class="mt-1 text-xs skill-count" style="color:#c9933a">246 skills</div>
        </a>
        <a href="https://github.com/jeffreytse/grimoire-core/tree/main/skills/business" target="_blank" class="p-4 domain-card" data-domain="business">
          <div class="mb-2 text-2xl">💼</div>
          <div class="text-sm font-semibold text-slate-200">Business</div>
          <div class="mt-1 text-xs skill-count" style="color:#c9933a">148 skills</div>
        </a>
        <a href="https://github.com/jeffreytse/grimoire-core/tree/main/skills/health" target="_blank" class="p-4 domain-card" data-domain="health">
          <div class="mb-2 text-2xl">🏥</div>
          <div class="text-sm font-semibold text-slate-200">Health</div>
