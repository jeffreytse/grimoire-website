<script is:inline>
  // Generate star field
  const starsEl = document.getElementById('stars');
  for (let i = 0; i < 80; i++) {
    const s = document.createElement('div');
    s.className = 'star';
    const size = Math.random() * 2 + 0.5;
    s.style.cssText = `width:${size}px;height:${size}px;left:${Math.random()*100}%;top:${Math.random()*100}%;--dur:${Math.random()*4+3}s;--delay:${Math.random()*4}s;--min-op:${Math.random()*0.1};--max-op:${Math.random()*0.4+0.1};`;
    starsEl.appendChild(s);
  }

  // Counter animation
  function animateCounter(el, target, duration) {
    duration = duration || 1400;
    let start = null;
    const step = function(ts) {
      if (!start) start = ts;
      const progress = Math.min((ts - start) / duration, 1);
      const ease = 1 - Math.pow(1 - progress, 3);
      el.textContent = Math.floor(ease * target);
      if (progress < 1) requestAnimationFrame(step);
      else el.textContent = target;
    };
    requestAnimationFrame(step);
  }

  // Scroll-reveal + counter trigger
  const observer = new IntersectionObserver(function(entries) {
    entries.forEach(function(entry) {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
        entry.target.querySelectorAll('[data-target]').forEach(function(el) {
          animateCounter(el, parseInt(el.dataset.target));
        });
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.15 });

  document.querySelectorAll('.reveal').forEach(function(el) { observer.observe(el); });

  // Tab switching
  function showTab(name) {
    document.querySelectorAll('.tab-content').forEach(function(el) { el.classList.add('hidden'); });
    document.querySelectorAll('.tab-btn').forEach(function(btn) {
      btn.classList.remove('active');
      btn.style.borderColor = '';
      btn.style.color = '';
    });
    document.getElementById('tab-' + name).classList.remove('hidden');
    event.currentTarget.classList.add('active');
    const skillsStep = document.getElementById('tab-skills-step');
    if (skillsStep) skillsStep.style.display = (name === 'claude') ? 'none' : '';
  }

  // OS detection
  (function() {
    const isWindows = /Win/i.test(navigator.platform || navigator.userAgent);
    if (isWindows) {
      const winCmd = 'irm https://raw.githubusercontent.com/jeffreytse/grimoire/main/scripts/install.ps1 | iex';
      const heroCmd = document.getElementById('hero-cmd');
      if (heroCmd) heroCmd.textContent = winCmd;
      document.querySelectorAll('.tab-content').forEach(function(el) { el.classList.add('hidden'); });
      document.querySelectorAll('.tab-btn').forEach(function(btn) { btn.classList.remove('active'); btn.style.borderColor = ''; });
      const winTab = document.getElementById('tab-win');
      const winBtn = document.getElementById('tab-btn-win');
      if (winTab) winTab.classList.remove('hidden');
      if (winBtn) { winBtn.classList.add('active'); winBtn.style.borderColor = 'rgba(201,147,58,0.5)'; }
    }
  })();

  // Copy to clipboard
  function copyText(text, btnId) {
    const btn = document.getElementById(btnId);
    function onSuccess() {
      if (!btn) return;
      const original = btn.textContent;
      btn.textContent = 'Copied!';
      btn.classList.add('copied');
      setTimeout(function() {
        btn.textContent = original;
        btn.classList.remove('copied');
      }, 2000);
    }
    function fallbackCopy(t, cb) {
      const ta = document.createElement('textarea');
      ta.value = t;
      ta.style.position = 'fixed';
      ta.style.opacity = '0';
      document.body.appendChild(ta);
      ta.focus();
      ta.select();
      try { document.execCommand('copy'); cb(); } catch(e) {}
      document.body.removeChild(ta);
    }
    if (navigator.clipboard && window.isSecureContext) {
      navigator.clipboard.writeText(text).then(onSuccess).catch(function() { fallbackCopy(text, onSuccess); });
    } else {
      fallbackCopy(text, onSuccess);
    }
  }

  // Apply skill counts to DOM
  function applySkillCounts(counts, total) {
    document.querySelectorAll('[data-domain]').forEach(function(card) {
      const count = counts[card.dataset.domain];
      if (count) card.querySelector('.skill-count').textContent = count + ' skills';
    });

    const domainCount = Object.keys(counts).filter(function(d) { return d !== 'meta'; }).length;

    const domainStatEl = document.querySelector('[data-target="26"]');
    if (domainStatEl) {
      if (domainStatEl.textContent !== '0') domainStatEl.textContent = domainCount;
      else domainStatEl.dataset.target = domainCount;
    }

    const labelEl = document.getElementById('domain-count-label');
    if (labelEl) labelEl.textContent = domainCount + ' Domains';

    ['domain-total-label', 'hero-total', 'cta-total', 'install-total-1', 'install-total-2', 'domains-section-total'].forEach(function(id) {
      const el = document.getElementById(id);
      if (el) el.textContent = total;
    });
    ['hero-domains', 'install-domains'].forEach(function(id) {
      const el = document.getElementById(id);
      if (el) el.textContent = domainCount;
    });
  }

  // Fetch live skill counts
  const SKILL_CACHE_KEY = 'grimoire_skill_counts';
  const SKILL_CACHE_TTL = 900000;

  async function fetchSkillCounts() {
    try {
      const cached = JSON.parse(localStorage.getItem(SKILL_CACHE_KEY) || 'null');
      if (cached && Date.now() - cached.ts < SKILL_CACHE_TTL) {
        applySkillCounts(cached.counts, cached.total);
        return;
      }
    } catch (_) {}

    try {
      const res = await fetch('https://api.github.com/repos/jeffreytse/grimoire-core/git/trees/main?recursive=1');
      const data = await res.json();
      const tree = data.tree;
      const counts = {};
      let total = 0;
      const re = /^skills\/([^/]+)\/(?:[^/]+\/)?skills\/[^/]+\/SKILL\.md$/;
      for (const item of tree) {
        const m = item.path.match(re);
        if (m) { counts[m[1]] = (counts[m[1]] || 0) + 1; if (m[1] !== 'meta') total++; }
      }
      localStorage.setItem(SKILL_CACHE_KEY, JSON.stringify({ counts, total, ts: Date.now() }));
      applySkillCounts(counts, total);
    } catch (_) {}
  }
  fetchSkillCounts();
</script>
