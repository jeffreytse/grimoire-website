---
import Layout from '../layouts/Layout.astro';
import NavSimple from '../components/NavSimple.astro';
import DomainsGrid from '../components/DomainsGrid.astro';
import AgentLinks from '../components/AgentLinks.astro';
import FooterSimple from '../components/FooterSimple.astro';
---

<Layout
  title="Grimoire for Codex — Best Practices Skills"
  description="1000+ best practices skills for OpenAI Codex CLI. Install Grimoire in 60 seconds and get expert frameworks for engineering, law, medicine, finance, and 26 domains."
  ogTitle="Grimoire for Codex — Best Practices Skills"
  ogDescription="Install 1000+ best practices skills into Codex CLI. Expert frameworks across 26 domains — free and open-source on GitHub. Auto-detected on install."
  ogImage="https://grimoire.jeffreytse.net/assets/banner-1280x640.svg"
  ogUrl="https://grimoire.jeffreytse.net/codex"
  canonical="https://grimoire.jeffreytse.net/codex"
  keywords="codex best practices, codex grimoire, codex skills, best practices skills, AI assistant skills, grimoire, open source AI skills"
>
  <Fragment slot="head">
    <script type="application/ld+json">{
  "@context": "https://schema.org",
  "@type": "HowTo",
  "name": "How to install Grimoire for Codex",
  "description": "Install 1000+ best practices skills into Codex in under 60 seconds.",
  "totalTime": "PT1M",
  "step": [
    { "@type": "HowToStep", "position": 1, "name": "Run the install command", "text": "grimoire install --target codex" },
    { "@type": "HowToStep", "position": 2, "name": "Skills install to ~/.agents/skills/", "text": "Grimoire installs 1000+ best practices skill files. Codex loads them automatically." },
    { "@type": "HowToStep", "position": 3, "name": "Start using best practices", "text": "Describe any task. Grimoire routes to the matching expert skill and applies it before Codex responds." }
  ]
}</script>
  </Fragment>

  <NavSimple />

  <main>

  <section class="px-6 py-20 text-center" style="background:#080c18">
    <div class="max-w-3xl mx-auto">
      <div class="mb-4 text-5xl">💻</div>
      <h1 class="mb-6 text-4xl font-black leading-tight tracking-tight md:text-6xl">
        <span class="text-white">Codex</span><br/>
        <span class="gold-gradient">Best Practices Skills</span>
      </h1>
      <p class="max-w-xl mx-auto mb-8 text-lg text-slate-400">
        Install 1000+ verified expert frameworks into Codex — engineering, law, medicine, finance, and 26 domains. Free and open-source.
      </p>
      <a href="https://github.com/jeffreytse/grimoire" target="_blank"
        class="inline-flex items-center gap-2 px-8 py-3.5 rounded-xl text-base font-bold transition-all"
        style="background:linear-gradient(135deg,#c9933a,#8b6220); color:#fff; box-shadow:0 4px 24px rgba(201,147,58,0.3)"
        onmouseover="this.style.transform='scale(1.03)'" onmouseout="this.style.transform='scale(1)'">
        View on GitHub →
      </a>
    </div>
  </section>

  <section class="px-6 py-16" style="background:#0d1120">
    <div class="max-w-2xl mx-auto">
      <p class="mb-3 text-sm font-semibold tracking-widest text-center uppercase" style="color:#c9933a">Installation</p>
      <h2 class="mb-8 text-3xl font-bold text-center text-white">Install Grimoire for Codex</h2>
      <div class="p-6 install-block">
        <pre class="text-sm text-slate-300 overflow-x-auto">curl -fsSL https://raw.githubusercontent.com/jeffreytse/grimoire/main/scripts/install.sh | bash
grimoire update
grimoire install --target codex</pre>
        <p class="mt-3 text-xs text-slate-400">Auto-detects Codex and installs to <code style="color:#e8d08a">~/.agents/skills/</code>.</p>
      </div>
      <p class="mt-4 text-sm text-center text-slate-400">Skills install to <code style="color:#e8d08a">~/.agents/skills/</code> — Codex loads them automatically.</p>
    </div>
  </section>

  <DomainsGrid />

  <section class="px-6 py-16" style="background:#0d1120">
    <div class="max-w-3xl mx-auto">
      <p class="mb-3 text-sm font-semibold tracking-widest text-center uppercase" style="color:#c9933a">FAQ</p>
      <h2 class="mb-10 text-3xl font-bold text-center text-white">Codex + Grimoire</h2>
      <div class="space-y-5">
        <div class="p-6 rounded-xl" style="background:#0d1120; border:1px solid #1e2a3a">
          <h3 class="mb-3 text-lg font-semibold text-white">Where does Grimoire install skills for Codex?</h3>
          <p class="text-slate-400">Skills are installed to ~/.agents/skills/. Codex CLI reads AGENTS.md and skills from this directory automatically on startup.</p>
        </div>
        <div class="p-6 rounded-xl" style="background:#0d1120; border:1px solid #1e2a3a">
          <h3 class="mb-3 text-lg font-semibold text-white">Does Grimoire auto-detect Codex?</h3>
          <p class="text-slate-400">Yes. The grimoire install script checks for the codex binary and installs to ~/.agents/skills/ automatically when Codex is detected.</p>
        </div>
        <div class="p-6 rounded-xl" style="background:#0d1120; border:1px solid #1e2a3a">
          <h3 class="mb-3 text-lg font-semibold text-white">Can I install only engineering skills for Codex?</h3>
          <p class="text-slate-400">Yes. Run grimoire --domain engineering --target codex to install only the engineering domain.</p>
        </div>
        <div class="p-6 rounded-xl" style="background:#0d1120; border:1px solid #1e2a3a">
          <h3 class="mb-3 text-lg font-semibold text-white">Does Grimoire work with all Codex versions?</h3>
          <p class="text-slate-400">Yes. Grimoire uses the AGENTS.md standard which Codex CLI supports from v0.1.0 onwards.</p>
        </div>
      </div>
    </div>
  </section>

  <AgentLinks />

  </main>

  <FooterSimple />

</Layout>
